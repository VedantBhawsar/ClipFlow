# ============================================================
# Shared
# ============================================================

NODE_ENV=development

# ============================================================
# Application
# ============================================================

PORT=4000
WEB_PORT=3001
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# Authentication
# ============================================================

AUTH_SECRET=replace-me-with-32-plus-random-chars
NEXTAUTH_SECRET=

JWT_SECRET=dev-secret-replace-me-with-32-plus-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=dev-encryption-key-replace-me-32-chars

# ============================================================
# Database & Redis
# ============================================================

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
BULLMQ_PREFIX=clipflow

# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_USER=clipflow
POSTGRES_PASSWORD=clipflow
POSTGRES_DB=clipflow

# ============================================================
# Redis
# ============================================================

# Uncomment if using authentication.
# REDIS_PASSWORD=change-me

# ============================================================
# Google OAuth
# ============================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ============================================================
# S3 / MinIO
# ============================================================

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=clipflow-videos
S3_FORCE_PATH_STYLE=true

# ============================================================
# YouTube
# ============================================================

YOUTUBE_CATEGORY_DEFAULT=22
YOUTUBE_MAX_VIDEO_BYTES=5368709120
YOUTUBE_PRESIGNED_POST_TTL=900

# ============================================================
# SMTP
# ============================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ============================================================
# AssemblyAI
# ============================================================

ASSEMBLYAI_API_KEY=

# ============================================================
# LLM
# ============================================================

LLM_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-70b-instruct

# ============================================================
# Image Generation
# ============================================================

IMAGE_GEN_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_VISION_MODEL=gemini-2.5-flash

REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-pro

THUMBNAILS_PER_VIDEO=5
THUMBNAIL_VISION_ENABLED=true

# ============================================================
# Rate Limiting
# ============================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
