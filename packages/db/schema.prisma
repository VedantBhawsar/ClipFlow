// packages/db/schema.prisma
//
// ClipFlow database schema. Mirrors docs/Schema.md, scoped to the tables
// needed for the v1 onboarding, settings, YouTube OAuth, and video
// upload → publish slices:
//
//   - User (auth identity)
//   - UserProfile (onboarding answers — niche/freq/goal)
//   - UserPreferences (runtime preferences — notifications, scheduling,
//     generation behavior)
//   - YouTubeChannel (OAuth connection for publishing)
//   - Video (uploaded videos + their publish lifecycle)
//
// Plan, Subscription, WebhookEvent, VideoStats, etc. are intentionally
// omitted from this file until their slices are built, to keep migrations
// honest and avoid declaring indexes/columns that nothing queries yet.
//
// VideoStatus is a 6-value subset for the upload-publish slice. The
// transcript / thumbnail / chapter-generation slice will extend the enum
// via a follow-up migration to add EXTRACTING / TRANSCRIBING / GENERATING
// / READY_FOR_REVIEW / FAILED.
//
// See docs/Schema.md for the full v1 picture and the v1.5 / v2 forward
// notes (VideoStats, multi-channel, etc.).
//
// Indexing strategy: v1 queries are dominated by owner-scoped lookups
// ("show me this user's profile / preferences / YouTube / videos") and
// the worker's scheduler scan ("videos with status=SCHEDULED whose
// scheduledPublishAt has passed"). Each model carries explicit composite
// indexes for those hot paths, in addition to the unique constraints
// on natural keys (id, email, googleId, userId 1:1s). FK columns already
// get an implicit index from Prisma; we only declare extras for query
// shapes that need a non-FK ordering or filter.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum ThumbnailSource {
  AI_GENERATED
  USER_UPLOADED
}

enum ThumbnailGenStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum ContentNiche {
  GAMING
  TECH_EDUCATION
  VLOG_LIFESTYLE
  BUSINESS_FINANCE
  ENTERTAINMENT_COMEDY
  OTHER
}

enum UploadFrequency {
  ONE_TO_FOUR
  FIVE_TO_TEN
  ELEVEN_TO_TWENTY
  TWENTY_PLUS
}

enum PrimaryGoal {
  SAVE_TIME_EDITING
  BETTER_THUMBNAILS_CTR
  CONSISTENT_SCHEDULE
  GROW_VIEWS
}

/// How the app should treat generated chapters before publishing.
/// ALWAYS_REVIEW: surface chapters in the review screen every time (default).
/// AUTO_APPLY_IF_VALID: if the LLM output passes YouTube's rules (first=0,
/// min 3, min 10s apart), apply without waiting for the user.
enum ChapterBehavior {
  ALWAYS_REVIEW
  AUTO_APPLY_IF_VALID
}

/// Per-user override for thumbnail style. AUTO means "use the niche
/// default" (the same lookup that runs today). The other values let
/// creators with multi-niche content force a consistent treatment.
enum ThumbnailStyleOverride {
  AUTO
  BOLD
  MINIMAL
  TEXT_FORWARD
}

/// Confidence flag for the personalized channel-style analysis.
/// HIGH = Gemini Vision returned a coherent style with at least one
/// non-default field. LOW = partial parse — we kept what we could and
/// the thumbnail worker falls back to niche-only prompts (no style
/// attribution) so we never invent a style the creator didn't have.
enum ChannelStyleConfidence {
  HIGH
  LOW
}

// ---------- Channel connection status ----------

enum ChannelConnectionStatus {
  CONNECTED
  NEEDS_REAUTH
  DISCONNECTED
}

// ---------- User ----------

/// Auth identity only. Onboarding answers live in UserProfile.
model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String?
  name            String?
  authProvider    AuthProvider @default(EMAIL)
  googleId        String?      @unique
  emailVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile        UserProfile?
  preferences    UserPreferences?
  youtubeChannel YouTubeChannel?
  videos         Video[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  thumbnailStyle      ChannelThumbnailStyle?
  subscription        Subscription?

  @@map("users")
@@index([id, email])
}

// ---------- Refresh tokens (rotation chain) ----------

/// One row per issued refresh token. Login mints the first row of a new
/// "family"; every successful /api/auth/refresh marks the presented token
/// as revoked and mints a new row in the SAME family. Presenting a token
/// that has already been revoked (i.e. was rotated past) revokes the
/// entire family — that's the standard OAuth 2.0 reuse-detection guard.
///
/// We store only the SHA-256 hash of the raw token; the raw value is sent
/// to the client and never persisted, so a DB compromise cannot replay
/// active sessions.
model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hash of the raw token (hex-encoded). The raw token is sent
  /// to the client in the response and never persisted.
  tokenHash String @unique

  /// Family groups the rotation chain. Login creates the first row of a
  /// new family; each rotation adds a new row with the SAME familyId.
  /// Reuse detection revokes every non-revoked row in the family.
  familyId String

  expiresAt DateTime

  /// Set when this token is rotated OR explicitly logged out. Used by
  /// the reuse-detection check on /api/auth/refresh.
  revokedAt DateTime?

  /// Best-effort audit fields. Populated when the issuer has access to
  /// the request — not enforced.
  userAgent String?
  ip        String?

  createdAt DateTime @default(now())

  // For "list this user's active sessions" admin views / future
  // "log out everywhere" UI.
  @@index([userId])
  // For bulk revocation when reuse is detected.
  @@index([familyId])
  // For background cleanup of expired rows.
  @@index([expiresAt])

  @@map("refresh_tokens")
}

// ---------- Password reset tokens ----------

/// One row per password reset request. Created when a user requests a
/// password reset; verified and consumed when they submit the new password
/// with a valid token. Tokens expire after a fixed window (1 hour) and
/// are single-use — usedAt marks consumption so the same token can't be
/// replayed.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hash of the raw reset token. The raw token is sent in the
  /// reset-link URL and never persisted.
  tokenHash String   @unique

  expiresAt DateTime
  /// Set when the token is consumed via a successful password reset.
  /// Null until used — once set the token cannot be reused.
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ---------- UserProfile ----------

/// Onboarding answers. Nullable until onboarding completes, so a
/// half-finished signup doesn't have to backfill later.
model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?

  niche           ContentNiche?
  uploadFrequency UploadFrequency?
  primaryGoal     PrimaryGoal?

  recommendedPlanId String?

  /// null until all required onboarding steps are done. Used to decide
  /// whether to redirect to the profile step or straight to the dashboard
  /// on login (per AppFlow.md edge case "user abandons mid-profile").
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

// ---------- UserPreferences ----------

/// Runtime user preferences (notifications, scheduling, generation).
///
/// Modeled separately from `UserProfile` so onboarding answers and
/// runtime preferences can evolve independently — and so the auth-critical
/// `User` table never needs to grow every time a new toggle is added.
/// Same separation rationale as `UserProfile` itself (see Schema.md).
///
/// Row is created on first read via service-layer upsert, so a returning
/// user always has preferences; explicit defaults live here so the API
/// contract is "if you PATCH with one field, the rest stay as-is."
model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ---- Notifications (email) ----
  notifyProcessingComplete Boolean @default(true)
  notifyPublished          Boolean @default(true)
  notifyPublishFailed      Boolean @default(true)
  notifyNeedsReauth        Boolean @default(true)
  notifyWeeklySummary      Boolean @default(false)

  // ---- Scheduling defaults ----
  /// IANA timezone string, e.g. "Asia/Kolkata". Validated application-side.
  defaultTimezone    String @default("UTC")
  /// HH:MM 24h local time, e.g. "18:00". Validated application-side.
  defaultPublishTime String @default("18:00")

  // ---- Generation behavior ----
  chapterBehavior ChapterBehavior        @default(ALWAYS_REVIEW)
  thumbnailStyle  ThumbnailStyleOverride @default(AUTO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ---------- YouTubeChannel ----------

/// Stores the OAuth connection between a User and their YouTube channel.
/// One channel per user (v1 limitation; v2 supports multi-channel).
/// Refresh tokens are encrypted at rest using AES-256-GCM.
model YouTubeChannel {
  id String @id @default(cuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The actual YouTube channel ID from Google
  youtubeChannelId String
  channelTitle String
  channelThumbnailUrl String?

  /// Encrypted refresh token (AES-256-GCM)
  refreshTokenEncrypted String
  scopes String

  status ChannelConnectionStatus @default(CONNECTED)
  lastVerifiedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos Video[]

  // For admin/ops lookups keyed by the upstream YouTube channel ID
  // (e.g. reverse-mapping an inbound Google webhook to a ClipFlow user).
  // userId already has a unique index (1:1 with User).
  @@index([youtubeChannelId])
  // For "find channels that need reauth" admin scans.
  @@index([status])

  @@map("youtube_channels")
}

// ---------- Video ----------

/// Lifecycle states for an uploaded video. Eleven values covering the
/// upload → extract → transcribe → generate → review → publish pipeline.
enum VideoStatus {
  /// Row exists, no bytes in S3 yet (or upload in progress).
  UPLOADED
  /// Bytes in S3, metadata accepted; preserved for back-compat with
  /// existing rows. The new flow bypasses READY entirely until
  /// ingest + transcribe + generate complete.
  READY
  /// Worker has started the audio/frame extraction pass.
  EXTRACTING
  /// Extraction complete; audio queued for transcription.
  TRANSCRIBING
  /// Transcription complete; thumbnail/chapter generation in progress.
  GENERATING
  /// Generation complete; awaiting creator review.
  READY_FOR_REVIEW
  /// `scheduledPublishAt` is in the future; BullMQ will pick it up later.
  SCHEDULED
  /// Worker has started the YouTube videos.insert call.
  PUBLISHING
  /// YouTube returned a videoId; `youtubeVideoId` and `publishedAt` are set.
  PUBLISHED
  /// Retries exhausted; see `failureReason` for the last error.
  PUBLISH_FAILED
  /// Extraction, transcription, or generation failed permanently;
  /// see `failureReason` for the error detail.
  FAILED
}

/// One row per uploaded video. Created in `UPLOADED` status when the
/// client submits metadata; transitions through the `VideoStatus` enum
/// as the upload → publish pipeline runs.
///
/// Cascade on `youtubeChannelId`: deleting the YouTube channel row
/// cascades to its videos. However, the disconnect endpoint sets
/// `status = "DISCONNECTED"` instead of deleting, so videos persist
/// when a user disconnects their YouTube account. They remain visible
/// in the dashboard but the publish/unpublish actions are hidden.
model Video {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeChannelId String
  youtubeChannel  YouTubeChannel @relation(fields: [youtubeChannelId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  tags            String[]
  categoryId      String        @default("22")
  privacyStatus   String        @default("private")

  // ---- YouTube content controls (status block) ----
  // Defaults match YouTube's own default behavior on `videos.insert`
  // so an absent field in the API still produces a sensible upload.
  // See @clipflow/types for the wire-shape union of each field.
  /// COPPA self-declaration. Once true on YouTube, can only be unset
  /// via Studio — we surface the choice prominently at upload time
  /// for that reason.
  madeForKids         Boolean @default(false)
  /// "none" (default, no restriction) | "18+" (YouTube content rating).
  ageRestriction      String  @default("none")
  /// status.embeddable — allow other sites to embed this video.
  embeddable          Boolean @default(true)
  /// status.license — "standard" | "creativeCommon".
  license             String  @default("standard")
  /// status.publicStatsViewable — show the public view count.
  publicStatsViewable Boolean @default(true)
  /// status.commentPolicy — "allowAll" | "holdAll" | "disable".
  commentPolicy       String  @default("allowAll")

  originalFilename String
  /// BigInt so we can represent up to the 5GB cap; `Int` is int4 (~2.1GB max).
  fileSizeBytes   BigInt
  contentType     String        @default("video/mp4")

  s3KeyOriginal   String        @unique

  /// Optional custom thumbnail. When set, the publish path forwards
  /// the S3 object to YouTube's `thumbnails.set` endpoint so the
  /// uploaded image (not a generated frame) becomes the video's
  /// thumbnail. YouTube rejects uploads >2 MB and non-image content
  /// types — both bounds are enforced at create time and on
  /// finalize so a bad object never reaches the YouTube API.
  s3KeyThumbnail     String?
  thumbnailContentType String?

  /// Key to the extracted MP3 audio. Used as input to the transcription
  /// pipeline. Null until the video-ingest worker completes extraction.
  s3KeyAudio         String?
  /// S3 key prefix under which extracted candidate frames live
  /// (`videos/{id}/frames/frame_NNN.jpg`). Together with `frameCount`
  /// this fully describes the thumbnail-source candidate set.
  s3KeyFramesPrefix  String?
  /// Number of extracted candidate frames. Null until extraction completes.
  frameCount         Int?
  /// Probed duration in seconds from the extracted audio. Used by the
  /// dashboard and (later) by the publish path to check against YouTube limits.
  durationSeconds     Int?

  /// S3 key of the AssemblyAI transcript JSON (full word-level timings +
  /// auto-chapters + sentiment). Null until the transcription worker
  /// completes. Kept on S3 (not inline JSONB) because the transcript can
  /// be hundreds of KB for a long video and is only fetched by the
  /// generate worker + review screen, never on the dashboard list.
  transcriptS3Key     String?
  /// ISO 639-1 language code returned by AssemblyAI's `language_detection`.
  /// Null until the transcription worker completes. Logged on the row so
  /// the dashboard can show a "(transcript: en)" hint without re-fetching.
  transcriptLanguage  String?
  /// Millisecond-precision audio duration from AssemblyAI. Null until
  /// the transcription worker completes. Strictly more precise than
  /// `durationSeconds` (FFprobe seconds) — used to align LLM-picked
  /// highlight timestamps against the transcript without rounding error.
  transcriptDurationMs Int?
  /// S3 prefix under which the LLM-picked highlight frames live
  /// (`videos/{id}/highlights/frame_NN.jpg`). Null until the generate
  /// worker completes. Together with `highlightsCount` this fully
  /// describes the topic-aligned cover candidates.
  highlightsS3Prefix  String?
  /// Number of LLM-selected highlight frames (capped at 5 in v1; tier
  /// caps re-enter when Imagen lands). Null until generation completes.
  highlightsCount     Int?
  /// LLM-emitted chapter list, validated against YouTube's chapter
  /// rules server-side (first timestamp = 0, min 3, min 10s apart, max
  /// 100 chars/title). Stored as JSONB so the publish path can read it
  /// without re-fetching from S3. Null until generation completes.
  chaptersJson        Json?

  status          VideoStatus   @default(UPLOADED)
  failureReason   String?

  scheduledPublishAt DateTime?
  youtubeVideoId  String?       @unique

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  thumbnails      Thumbnail[]
  thumbnailGenerations ThumbnailGeneration[]

  @@index([userId, status])
  // Dashboard's "my videos, newest first" list. The composite (userId,
  // createdAt DESC) lets Postgres satisfy both the filter and the
  // ordering from the index without a sort step.
  @@index([userId, createdAt(sort: Desc)])
  @@index([scheduledPublishAt])
  @@index([status, scheduledPublishAt])
  /// The user-selected thumbnail for this video. Null until the user
  /// picks one during review. Application-resolved (no Prisma relation
  /// needed — the service layer handles consistency).
  selectedThumbnailId String?  @unique

  @@map("videos")
}

// ---------- Thumbnail ----------

/// One generated thumbnail candidate for a video. Multiple thumbnails
/// per video (tier-capped at generation time). The `generationIndex`
/// tracks which attempt produced this thumbnail, so the UI can show
/// "3 of 5 regenerations used" per the tier limit.
model Thumbnail {
  id              String          @id @default(cuid())
  videoId         String
  video           Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)

  s3Key           String
  source          ThumbnailSource @default(AI_GENERATED)
  generationIndex Int             @default(0)

  /// Optional metadata for display
  width           Int?
  height          Int?
  fileSizeBytes   Int?

  createdAt       DateTime        @default(now())

  @@index([videoId])
  @@map("thumbnails")
}

// ---------- ThumbnailGeneration ----------

/// Logs every thumbnail generation attempt — what prompt was used,
/// which model, which chapter/frame references, and the outcome.
/// Enables debugging failed generations and showing usage to the user.
model ThumbnailGeneration {
  id              String            @id @default(cuid())
  videoId         String
  video           Video             @relation(fields: [videoId], references: [id], onDelete: Cascade)

  status          ThumbnailGenStatus @default(PENDING)

  /// The full prompt sent to the image generation model
  promptText      String            @db.Text
  /// Which model was used (e.g. "gemini-2.0-flash", "replicate-flux-1.1")
  modelUsed       String

  /// References to chapters used for picking frames (JSON array of { startMs, title })
  chapterRefs     Json?
  /// S3 keys of the source frames used as composition base
  frameRefs       Json?
  /// Which channel style profile was used (nullable if not yet analyzed)
  channelStyleId  String?

  /// IDs of the Thumbnail rows produced by this generation
  generatedIds    String[]

  /// Error details when status = FAILED
  errorCode       String?
  errorMessage    String?           @db.Text

  createdAt       DateTime          @default(now())
  completedAt     DateTime?

  @@index([videoId])
  @@map("thumbnail_generations")
}

// ---------- ChannelThumbnailStyle ----------

/// Cached analysis of a creator's existing YouTube thumbnails.
/// Populated by the `channel-style-analyze` worker job, which sends
/// recent thumbnails to Gemini Vision for pattern extraction.
/// The `styleOverride` lets the user manually override the detected style.
model ChannelThumbnailStyle {
  id              String                @id @default(cuid())
  userId          String                @unique
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Vision analysis results
  /// Array of hex color strings representing the dominant palette
  dominantColors  Json?
  /// "top" | "bottom" | "center" | "left" | "right" | "mixed"
  textPlacement   String?
  /// "face-focused" | "text-heavy" | "minimalist" | "busy" | "split"
  compositionStyle String?
  /// "always" | "often" | "sometimes" | "rarely"
  facePresence    String?
  /// Array of detected brand elements (logos, watermarks, recurring graphics)
  brandElements   Json?

  /// Raw analysis text from Gemini (free-form observations)
  analysisRaw     String?             @db.Text

  /// Manual user override — AUTO means "use detected style"
  styleOverride   ThumbnailStyleOverride @default(AUTO)

  /// URLs the user explicitly picked for the analysis (1–4). Set during
  /// the onboarding wizard's step 5 and on "Refresh my channel style"
  /// re-runs from the settings page. Empty array means the auto-pick
  /// flow ran (the worker's `search.list` chose the thumbnails).
  selectedThumbnailUrls String[]            @default([])

  /// HIGH = Gemini Vision returned a parseable style with at least one
  /// non-default field. LOW = partial parse — consumers (the thumbnail
  /// worker) fall back to niche-only prompts to avoid inventing a
  /// style the creator didn't have.
  confidence      ChannelStyleConfidence @default(HIGH)

  /// When `confidence = LOW`, why we couldn't extract a full style.
  /// Free-form, machine-readable prefix (e.g. "[VISION_PARTIAL_PARSE]")
  /// so support can grep for known causes.
  lowConfidenceReason String?

  /// How many thumbnails were analyzed in the last run
  thumbnailCount  Int                 @default(0)
  lastAnalyzedAt  DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("channel_thumbnail_styles")
}

// ---------- Billing ----------

enum SubscriptionStatus {
  ACTIVE
  ON_HOLD
  CANCELED
  EXPIRED
}

enum PlanInterval {
  MONTH
  YEAR
}

model Plan {
  id               String       @id @default(cuid())
  key              String       @unique
  name             String
  priceUsd         Int
  videosPerMonth   Int
  thumbnailsPerVideo Int
  interval         PlanInterval @default(MONTH)
  dodoProductId    String?      @unique
  isHighlighted    Boolean      @default(false)
  sortOrder        Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status              SubscriptionStatus @default(ACTIVE)
  dodoSubscriptionId  String?            @unique
  dodoCustomerId      String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  videosUsedThisPeriod   Int             @default(0)
  thumbnailsUsedThisPeriod Int           @default(0)
  paymentFailedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String
  eventId   String
  eventType String
  payload   Json
  processedAt DateTime?
  attempts   Int     @default(1)
  lastError  String?

  receivedAt DateTime @default(now())

  @@unique([provider, eventId])
  @@index([provider, receivedAt])
  @@map("webhook_events")
}
