{
  "name": "@clipflow/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prisma:generate": "prisma generate --schema=./schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./schema.prisma",
    "prisma:studio": "prisma studio --schema=./schema.prisma",
    "check-types": "tsc --noEmit",
    "postinstall": "prisma generate --schema=./schema.prisma && ln -sf $(readlink -f node_modules/@prisma/client)/../.prisma node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@clipflow/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "5.9.2"
  },
  "prisma": {
    "schema": "schema.prisma"
  }
}