NODE_ENV=development
DATABASE_URL=postgresql://clipflow:clipflow@localhost:5432/clipflow
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=clipflow
JWT_SECRET=dev-secret-replace-me-with-32-plus-chars
ENCRYPTION_KEY=dev-encryption-key-replace-me-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=clipflow-videos
S3_FORCE_PATH_STYLE=true
YOUTUBE_CATEGORY_DEFAULT=22
YOUTUBE_MAX_VIDEO_BYTES=5368709120
YOUTUBE_PRESIGNED_POST_TTL=900
ASSEMBLYAI_API_KEY=
# --- LLM (generate stage) ---
# `nvidia` (default) talks to NVIDIA NIM via the OpenAI SDK.
# `openai` talks to api.openai.com via the OpenAI SDK.
# `claude` is reserved for a future Anthropic adapter (not implemented).
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-70b-instruct