NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://clipflow:clipflow@localhost:5432/clipflow
# REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-replace-me-with-32-plus-chars
# Short-lived access token. NextAuth on the frontend silently refreshes
# via /api/auth/refresh when this expires.
JWT_EXPIRES_IN=15m
# Long-lived refresh token. Rotation + reuse detection — a leaked token
# is bounded to this window.
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=dev-encryption-key-replace-me-32-chars
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# S3 / MinIO (default values match docker-compose.yml)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=clipflow-videos
S3_FORCE_PATH_STYLE=true
# BullMQ
BULLMQ_PREFIX=clipflow
# YouTube limits
YOUTUBE_CATEGORY_DEFAULT=22
YOUTUBE_MAX_VIDEO_BYTES=5368709120
YOUTUBE_PRESIGNED_POST_TTL=900
# SMTP (transactional email — password reset, notifications)
# Comment out SMTP_HOST to skip email sending entirely (fine for local dev).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM=ClipFlow <noreply@yourdomain.com>

# --- AI Thumbnail Generation ---
# IMAGE_GEN_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_VISION_MODEL=gemini-2.5-flash
# REPLICATE_API_TOKEN=
# REPLICATE_IMAGE_MODEL=black-forest-labs/flux-pro
# THUMBNAILS_PER_VIDEO=5
# THUMBNAIL_VISION_ENABLED=true

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
