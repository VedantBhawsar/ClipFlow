    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dodopayments": "^2.42.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
