{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@clipflow/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
